---
const services = [
  {
    title: 'Media Production',
    desc: 'Full-scale video and photo production for brands',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.9L15 14"/><rect x="3" y="8" width="12" height="8" rx="2"/></svg>`,
  },
  {
    title: 'Social Media Management',
    desc: 'Strategy, content, and consistency for your channels',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="18" cy="5" r="2"/><circle cx="6" cy="12" r="2"/><circle cx="18" cy="19" r="2"/><path d="M8 12h8M8 6.5l7.5 2M8 17.5l7.5-2"/></svg>`,
  },
  {
    title: 'Personalized Photoshoot',
    desc: 'Tailored portrait and editorial sessions',
    exampleHref: '/portfolio/personal',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
  },
  {
    title: 'UGC Creation',
    desc: 'Authentic user-generated style content for campaigns',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/><path d="M9 7h6M9 11h4"/></svg>`,
  },
  {
    title: 'Modeling',
    desc: 'Editorial, commercial, and creative direction',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="5" r="2"/><path d="M12 7v6l-3 4m3-4l3 4M9 11H7m10 0h-2"/></svg>`,
  },
  {
    title: 'Abilities & Roles',
    desc: 'Multidisciplinary creative available for collaborations',
    exampleHref: '/portfolio/personal',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  },
];
---

<section
  id="services"
  class="py-section px-site"
  aria-labelledby="services-heading"
>
  <div data-reveal>
    <h2
      id="services-heading"
      style="font-family: 'Anton', sans-serif; font-size: clamp(2rem, 6vw, 4rem); color: #0A0A0A; line-height: 1; letter-spacing: -0.02em;"
    >
      PHOZARO OFFERS
    </h2>
    <p
      style="font-family: 'Inter', sans-serif; font-size: 1rem; color: #6B6B6B; font-style: italic; margin-top: 0.5rem; margin-bottom: 3rem;"
    >
      It's time to create.
    </p>
  </div>

  <div class="services-grid">
    {services.map((s) => (
      <div class="service-card" data-reveal>
        <div class="service-card__icon" set:html={s.icon} />
        <p class="service-card__title">{s.title}</p>
        <p class="service-card__desc">{s.desc}</p>
        <a href={s.exampleHref} class="service-card__example-btn">
          See example in portfolio →
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: #FAFAF9;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: clamp(2rem, 4vw, 3rem);
    transition: border-color 300ms ease, background 300ms ease;
  }
  .service-card:hover {
    border-color: #D0CFC9;
    background: #F5F4F0;
  }

  .service-card__icon {
    color: #0A0A0A;
    margin-bottom: 1.5rem;
    line-height: 0;
  }

  .service-card__title {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0A0A0A;
    margin: 0;
  }
  .service-card__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #6B6B6B;
    margin-top: 0.5rem;
    line-height: 1.7;
    flex: 1;
  }

  .service-card__example-btn {
    display: inline-block;
    align-self: flex-start;
    margin-top: 1.75rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: #0A0A0A;
    text-decoration: none;
    border: 1px solid #D0D0D0;
    border-radius: 999px;
    padding: 0.45rem 1rem;
    letter-spacing: 0.03em;
    transition: border-color 200ms ease, background 200ms ease, color 200ms ease;
  }
  .service-card__example-btn:hover {
    border-color: #0A0A0A;
    background: #0A0A0A;
    color: #ffffff;
  }
</style>
