---
const services = [
  {
    title: 'Media Production',
    desc: 'Full-scale video and photo production for brands',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <path d="M6 14 C5.8 13.9 5.9 34 6.1 34.1 C6.3 34.2 29.8 34.3 30 34 C30.2 33.7 30.1 14.2 30 14 C29.9 13.8 6.2 14.1 6 14Z"/>
      <path d="M30 19.5 L39 15.2 C39.5 15 40 15.3 40 15.9 L40 32.1 C40 32.7 39.5 33 39 32.8 L30 28.5"/>
      <circle cx="18" cy="24" r="5.5"/>
    </svg>`,
  },
  {
    title: 'Social Media Management',
    desc: 'Strategy, content, and consistency for your channels',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <circle cx="36" cy="10" r="4.5"/>
      <circle cx="12" cy="24" r="4.5"/>
      <circle cx="36" cy="38" r="4.5"/>
      <path d="M16.3 21.8 L31.8 13.2"/>
      <path d="M16.3 26.2 L31.8 34.8"/>
    </svg>`,
  },
  {
    title: 'Personalized Photoshoot',
    desc: 'Tailored portrait and editorial sessions',
    exampleHref: '/portfolio/personal',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <path d="M4 17 C3.9 16.8 4 37.9 4.2 38.1 C4.4 38.3 43.7 38.2 44 38 C44.3 37.8 44 17.2 44 17 C43.8 16.8 33.5 16.9 33 17 L30 11 L18 11 L15 17 C14.5 17.1 4.1 17.2 4 17Z"/>
      <circle cx="24" cy="27" r="7.5"/>
      <circle cx="37" cy="21" r="2"/>
    </svg>`,
  },
  {
    title: 'UGC Creation',
    desc: 'Authentic user-generated style content for campaigns',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <path d="M15 4 C14.8 3.9 33 3.8 33.2 4.1 C33.4 4.4 33.3 43.8 33 44 C32.7 44.2 15.2 44.1 15 44 C14.8 43.9 14.9 4.1 15 4Z"/>
      <line x1="21" y1="10" x2="27" y2="10"/>
      <circle cx="24" cy="38" r="2.5"/>
      <line x1="20" y1="20" x2="28" y2="20"/>
      <line x1="20" y1="26" x2="25" y2="26"/>
    </svg>`,
  },
  {
    title: 'Modeling',
    desc: 'Editorial, commercial, and creative direction',
    exampleHref: '/portfolio/marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <circle cx="24" cy="9" r="5"/>
      <path d="M24 14 C23.8 14 24 26 24 26"/>
      <path d="M24 26 L16 38"/>
      <path d="M24 26 L32 38"/>
      <path d="M16 22 L32 22"/>
    </svg>`,
  },
  {
    title: 'Abilities & Roles',
    desc: 'Multidisciplinary creative available for collaborations',
    exampleHref: '/portfolio/personal',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 48 48">
      <path d="M24 4 L28.5 16.5 L42 17.5 L32 26.5 L35.5 40 L24 33 L12.5 40 L16 26.5 L6 17.5 L19.5 16.5 Z"/>
    </svg>`,
