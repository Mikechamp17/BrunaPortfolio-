---
import { Image } from 'astro:assets';
import SectionMarker from './SectionMarker.astro';
import VimeoEmbed from './VimeoEmbed.astro';
import { getCollection } from 'astro:content';
import portrait from '../assets/portrait.jpg';

const videos = (await getCollection('videos')).sort((a, b) => a.data.order - b.data.order);
const reel = videos[0];
---

<section
  id="about"
  class="py-section"
  aria-labelledby="about-heading"
>
  <h2 id="about-heading" class="sr-only">About</h2>
  <SectionMarker word="ABOUT" />

  <!-- Row 1: Portrait + Bio -->
  <div class="px-site mt-8 md:mt-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
      <!-- Portrait -->
      <!-- REPLACE: swap src/assets/portrait.jpg with PHOZARO's actual portrait, keep filename -->
      <div data-reveal>
        <Image
          src={portrait}
          alt="PHOZARO portrait"
          width={700}
          format="webp"
          quality={85}
          loading="lazy"
          decoding="async"
          style="width: 100%; height: auto; display: block;"
        />
      </div>

      <!-- Bio + clients -->
      <div class="flex flex-col gap-10" data-reveal>
        <div class="flex flex-col gap-6">
          <p class="eyebrow">Biography</p>
          <p class="text-base leading-relaxed text-ink" style="max-width: 52ch;">
            PHOZARO is a Malta-based photographer, filmmaker, and content creator
            working at the intersection of visual storytelling, brand identity,
            and digital media. Every frame is intentional. Every project is
            personal. Available for editorial, commercial, and creative
            collaborations worldwide.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <p class="eyebrow">Selected clients</p>
          <p class="text-sm leading-relaxed" style="color: #6B6B6B;">
            Gaura Sumer · Browns Pharmacy · Malta Airport · McDonald's Malta · Balanced Lifestore · Maduma Reels
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 2: Featured Video -->
  {reel && (
    <div class="px-site mt-16 md:mt-24" data-reveal>
      <p class="eyebrow">Featured Video</p>
      <!-- REPLACE: update vimeoId in src/content/videos/reel.json with the number from your Vimeo URL (e.g. vimeo.com/123456789 -> use 123456789) -->
      <VimeoEmbed
        vimeoId={reel.data.vimeoId}
        title={reel.data.title}
        poster={reel.data.poster}
      />
    </div>
  )}
</section>
