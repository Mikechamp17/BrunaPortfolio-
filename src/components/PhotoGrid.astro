---
import { getCollection } from 'astro:content';
import PhotoItem from './PhotoItem.astro';

interface Props {
  category?: 'marketing' | 'personal';
}
const { category } = Astro.props;

const allPhotos = (await getCollection('photos')).sort(
  (a, b) => a.data.order - b.data.order
);
const photos = category
  ? allPhotos.filter((p) => p.data.category === category)
  : allPhotos;
---

<div class="photo-grid" id={`photo-gallery-${category ?? 'all'}`}>
  {photos.map((photo) => (
    <PhotoItem
      src={photo.data.src}
      alt={photo.data.alt}
      aspectRatio={photo.data.aspectRatio}
      caption={photo.data.caption}
    />
  ))}
</div>

<script>
  import '../scripts/lightbox';
</script>
