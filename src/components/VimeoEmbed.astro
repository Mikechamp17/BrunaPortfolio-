---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  vimeoId: string;
  title: string;
  poster: ImageMetadata;
}

const { vimeoId, title, poster } = Astro.props;
const embedUrl = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0`;
---

<div
  class="vimeo-wrapper"
  data-vimeo-id={vimeoId}
  data-embed-url={embedUrl}
  data-title={title}
>
  <!-- Poster shown until in-viewport -->
  <Image
    src={poster}
    alt={`${title} — play video`}
    width={1920}
    format="webp"
    quality={80}
    loading="lazy"
    decoding="async"
    id={`vimeo-poster-${vimeoId}`}
  />
  <button
    class="absolute inset-0 flex items-center justify-center bg-transparent border-none cursor-pointer w-full h-full"
    aria-label={`Play ${title}`}
    id={`vimeo-btn-${vimeoId}`}
  >
    <!-- Play icon -->
    <div
      style="width: 72px; height: 72px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center;"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="#0A0A0A" aria-hidden="true">
        <polygon points="5,3 19,12 5,21" />
      </svg>
    </div>
  </button>
</div>

<script>
  // Lazy-load Vimeo iframe on intersection or click
  const wrappers = document.querySelectorAll<HTMLElement>('.vimeo-wrapper');

  wrappers.forEach((wrapper) => {
    const embedUrl = wrapper.dataset.embedUrl!;
    const vimeoId = wrapper.dataset.vimeoId!;
    const btn = wrapper.querySelector<HTMLButtonElement>(`#vimeo-btn-${vimeoId}`);

    const loadIframe = () => {
      if (wrapper.querySelector('iframe')) return;
      const iframe = document.createElement('iframe');
      iframe.src = embedUrl;
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = wrapper.dataset.title ?? 'Video';
      wrapper.appendChild(iframe);
      // Hide poster and button
      wrapper.querySelector('img')?.remove();
      btn?.remove();
    };

    btn?.addEventListener('click', loadIframe);

    // Also load when scrolled into view (without autoplay)
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          // Pre-connect to Vimeo but don't autoplay — wait for click
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );
    observer.observe(wrapper);
  });
</script>
