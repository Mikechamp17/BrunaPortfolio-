---
---
<nav
  class="fixed top-0 left-0 right-0 z-40 flex items-center justify-between"
  style="padding: clamp(1.25rem, 2.5vw, 2rem) clamp(1.5rem, 4vw, 4rem);"
  aria-label="Main navigation"
>
  <!-- Logo -->
  <a
    href="#home"
    class="text-ink font-medium text-sm tracking-widest uppercase no-underline"
    style="font-family: 'Inter', sans-serif; letter-spacing: 0.15em;"
    aria-label="Bruna — back to top"
  >
    Bruna
  </a>

  <!-- Desktop nav -->
  <ul class="hidden md:flex gap-8 list-none m-0 p-0" role="list">
    {[
      { href: '#photography', label: 'Photography' },
      { href: '#videography', label: 'Videography' },
      { href: '#about', label: 'About' },
      { href: '#contact', label: 'Contact' },
    ].map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="text-ink text-base font-medium no-underline transition-opacity duration-200 hover:opacity-60"
          style="font-family: 'Inter', sans-serif;"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Hamburger (mobile) -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col gap-[5px] cursor-pointer bg-transparent border-none p-2"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-overlay"
  >
    <span class="block w-6 h-px bg-ink transition-all duration-300" id="hamburger-top"></span>
    <span class="block w-6 h-px bg-ink transition-all duration-300" id="hamburger-mid"></span>
    <span class="block w-4 h-px bg-ink transition-all duration-300" id="hamburger-bot"></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="nav-overlay" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <button
    id="nav-close"
    class="absolute top-0 right-0 bg-transparent border-none cursor-pointer p-8"
    style="font-family: 'Inter', sans-serif; font-size: 1rem; color: #6B6B6B;"
    aria-label="Close menu"
  >
    Close
  </button>
  <ul class="list-none m-0 p-0 flex flex-col items-center gap-10" role="list">
    {[
      { href: '#photography', label: 'Photography' },
      { href: '#videography', label: 'Videography' },
      { href: '#about', label: 'About' },
      { href: '#contact', label: 'Contact' },
    ].map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="text-ink no-underline nav-overlay-link"
          style="font-family: 'Anton', sans-serif; font-size: clamp(2.5rem, 8vw, 5rem); line-height: 1;"
          data-nav-close
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script src="../scripts/nav.ts"></script>
