---
import SectionMarker from './SectionMarker.astro';

interface Props {
  email: string;
  instagram: string;
  location: string;
}
const { email, instagram, location } = Astro.props;
---

<section
  id="contact"
  class="py-section"
  aria-labelledby="contact-heading"
>
  <h2 id="contact-heading" class="sr-only">Contact</h2>
  <SectionMarker word="CONTACT" />

  <div class="px-site mt-8 md:mt-16 flex justify-center">
    <div class="flex flex-col items-center gap-8 text-center" data-reveal>
      <p class="text-xs font-medium uppercase tracking-widest text-ink" style="letter-spacing: 0.15em;">
        Get in touch
      </p>

      <div class="flex flex-col gap-4">
        <a
          href={`mailto:${email}`}
          class="text-ink no-underline hover:opacity-60 transition-opacity duration-200"
          style="font-family: 'Anton', sans-serif; font-size: clamp(1.25rem, 4vw, 3.5rem); line-height: 1.1; word-break: break-all;"
        >
          {email}
        </a>
      </div>

      <div class="flex gap-10 items-center">
        <a
          href={`https://instagram.com/${instagram.replace('@', '')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-ink no-underline hover:opacity-60 transition-opacity duration-200"
          aria-label={`Instagram: ${instagram}`}
        >
          {instagram}
        </a>
        <span style="color: #E8E8E8;" aria-hidden="true">·</span>
        <p class="text-sm font-medium text-ink m-0">{location}</p>
      </div>
    </div>
  </div>
</section>
