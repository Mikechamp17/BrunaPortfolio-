---
interface Props {
  name: string;
}
const { name } = Astro.props;
---
<section
  id="home"
  class="relative min-h-screen flex items-center justify-center px-site"
  aria-labelledby="hero-heading"
>
  <h1
    id="hero-heading"
    class="section-marker"
    aria-label={name}
    style="color: #0A0A0A;"
  >
    {name.toUpperCase()}
  </h1>
</section>
