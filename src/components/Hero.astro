---
interface Props {
  name: string;
  tagline: string;
}
const { name, tagline } = Astro.props;
---

<section
  id="home"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
  aria-label="PHOZARO — More than the eyes can reach"
>
  <!-- Background: dark gradient placeholder -->
  <!-- REPLACE: drop hero-reel.mp4 into src/assets/ and swap this div for:
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
      <source src="/hero-reel.mp4" type="video/mp4" />
    </video>
  -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);"
    aria-hidden="true"
  ></div>

  <!-- Overlay -->
  <div
    class="absolute inset-0"
    style="background: rgba(0,0,0,0.35);"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center text-center px-site">
    <!-- Eyebrow -->
    <p
      style="font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 500; color: white; opacity: 0.8; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1.5rem;"
    >
      Photographer · Filmmaker · Content Creator
    </p>

    <!-- Giant name -->
    <h1
      style="font-family: 'Anton', sans-serif; font-size: clamp(4.5rem, 18vw, 18rem); color: white; line-height: 1; letter-spacing: -0.02em;"
    >
      {name}
    </h1>

    <!-- Tagline -->
    <p
      style="font-family: 'Inter', sans-serif; font-size: clamp(0.9rem, 1.5vw, 1.1rem); color: white; opacity: 0.7; font-style: italic; margin-top: 1.5rem;"
    >
      {tagline}
    </p>
  </div>

  <!-- Scroll arrow -->
  <div
    class="hero-scroll-arrow absolute bottom-10 left-1/2"
    style="transform: translateX(-50%); color: white; font-size: 1.5rem; opacity: 0.6;"
    aria-hidden="true"
  >
    ↓
  </div>
</section>
