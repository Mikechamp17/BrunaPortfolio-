---
import { Image } from 'astro:assets';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  aspectRatio: '3/4' | '1/1' | '4/3' | '16/9';
  caption?: string;
}

const { src, alt, aspectRatio, caption } = Astro.props;

const fullImage = await getImage({
  src,
  format: 'webp',
  quality: 90,
  width: Math.min(src.width, 2000),
});
---

<a
  class="photo-item"
  href={fullImage.src}
  data-pswp-width={src.width}
  data-pswp-height={src.height}
  data-pswp-caption={caption}
  data-reveal
  aria-label={caption ?? alt}
>
  <Image
    src={src}
    alt={alt}
    width={900}
    format="webp"
    quality={80}
    loading="lazy"
    decoding="async"
    style={`aspect-ratio: ${aspectRatio};`}
  />
  {caption && (
    <span class="photo-item__caption" aria-hidden="true">
      <span class="photo-item__caption-text">{caption}</span>
    </span>
  )}
</a>
