---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import SectionMarker from '../components/SectionMarker.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---

<Base
  title={`${site.name} — ${site.tagline}`}
  description="PHOZARO is a Malta-based photographer, filmmaker, and content creator working at the intersection of visual storytelling, brand identity, and digital media."
>
  <Nav />

  <main id="main">
    <Hero name={site.name} tagline={site.tagline} />

    <Services />

    <!-- Portfolio -->
    <section id="portfolio" class="py-section" aria-labelledby="portfolio-heading">
      <h2 id="portfolio-heading" class="sr-only">Portfolio</h2>
      <SectionMarker word="PORTFOLIO" />

      <!-- Multimedia Marketing -->
      <div class="px-site mt-8 md:mt-16">
        <p class="eyebrow">Multimedia Marketing</p>
        <PhotoGrid category="marketing" />
        <p class="brands-strip">
          Gaura Sumer Campaign · Browns Pharmacy · Malta Airport · McDonald's Malta · Balanced Lifestore · Maduma Reels
        </p>
      </div>

      <!-- Personal Work -->
      <div class="px-site" style="margin-top: clamp(5rem, 10vw, 9rem);">
        <p class="eyebrow">Personal Work</p>
        <PhotoGrid category="personal" />
        <p class="brands-strip">
          Creative Media Production · Urban · Nature · UGC Creation
        </p>
      </div>
    </section>

    <About />

    <Contact
      email={site.email}
      instagram={site.instagram}
      location={site.location}
    />
  </main>

  <Footer />
</Base>

<script>
  import '../scripts/lenis';
  import '../scripts/reveal';
</script>
