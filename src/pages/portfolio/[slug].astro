---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import VimeoEmbed from '../../components/VimeoEmbed.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, coverImage, images, vimeoId, category } = project.data;

const categoryLabel = category === 'marketing' ? 'Multimedia Marketing' : 'Personal Work';
---

<Base title={`${title} — PHOZARO`} description={description}>
  <Nav />

  <main id="main">

    <!-- Project hero -->
    <section
      class="relative"
      style="min-height: 65vh; display: flex; align-items: flex-end;"
    >
      <!-- Cover image -->
      <div class="absolute inset-0 overflow-hidden">
        <Image
          src={coverImage}
          alt={title}
          width={1600}
          format="webp"
          quality={85}
          style="width: 100%; height: 100%; object-fit: cover; display: block;"
        />
        <!-- Dark overlay so text is readable -->
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 60%);"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Text over image -->
      <div class="relative z-10 px-site pb-12 md:pb-20 w-full">
        <!-- Back link -->
        <a
          href="/#portfolio"
          class="inline-block no-underline mb-6"
          style="font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.7); letter-spacing: 0.12em; text-transform: uppercase;"
        >
          ← Portfolio / {categoryLabel}
        </a>

        <!-- Project title -->
        <h1
          style="font-family: 'Anton', sans-serif; font-size: clamp(3rem, 10vw, 9rem); color: white; line-height: 1; letter-spacing: -0.02em; margin: 0;"
        >
          {title}
        </h1>
      </div>
    </section>

    <!-- Description -->
    <div class="px-site py-16 md:py-24" style="max-width: 70ch;">
      <p
        class="eyebrow"
        style="margin-bottom: 1.25rem;"
      >
        About this project
      </p>
      <p style="font-family: 'Inter', sans-serif; font-size: 1.05rem; color: #0A0A0A; line-height: 1.8;">
        {description}
      </p>
    </div>

    <!-- Photo gallery (if images exist) -->
    {images && images.length > 0 && (
      <div class="px-site pb-16 md:pb-24">
        <p class="eyebrow" style="margin-bottom: 2rem;">Gallery</p>
        <div class="project-gallery">
          {images.map((img, i) => (
            <div class="project-gallery__item" data-reveal>
              <Image
                src={img}
                alt={`${title} — image ${i + 1}`}
                width={1200}
                format="webp"
                quality={85}
                loading="lazy"
                decoding="async"
                style="width: 100%; height: auto; display: block;"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Vimeo embed (if video project) -->
    {vimeoId && (
      <div class="px-site pb-16 md:pb-24" data-reveal>
        <p class="eyebrow" style="margin-bottom: 2rem;">Video</p>
        <VimeoEmbed vimeoId={vimeoId} title={title} />
      </div>
    )}

    <!-- Back to portfolio -->
    <div class="px-site pb-24 border-t" style="padding-top: 3rem; border-color: #E8E8E8;">
      <a
        href="/#portfolio"
        class="no-underline"
        style="font-family: 'Anton', sans-serif; font-size: clamp(1.25rem, 3vw, 2rem); color: #0A0A0A; transition: opacity 300ms ease;"
        onmouseover="this.style.opacity='0.5'"
        onmouseout="this.style.opacity='1'"
      >
        ← Back to Portfolio
      </a>
    </div>

  </main>

  <Footer />
</Base>

<style>
  .project-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .project-gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .project-gallery {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .project-gallery__item {
    overflow: hidden;
  }
  .project-gallery__item img {
    transition: transform 600ms ease-out;
  }
  .project-gallery__item:hover img {
    transform: scale(1.03);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-gallery__item img { transition: none; }
  }
</style>

<script>
  import '../../scripts/reveal';
</script>
